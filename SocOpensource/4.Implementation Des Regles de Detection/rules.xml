<!-- Detection Ping -->
<group name="zeek_custom,">

  <!-- Detection : Ping Flood -->
  <rule id="100001" level="11">
    <match>ALERTE_PING_FLOOD</match>
    <description>Zeek IDS: Ping Flood détecté de $(srcip) vers $(dstip)</description>
    <group>network_attack,icmp_flood</group>
    <mitre>
        <id>T1046</id>
    </mitre>
  </rule>
  
  <!-- Detection : Ping Sweep -->
  <rule id="100002" level="11">
    <match>ALERTE_PING_SWEEP</match>
    <description>Zeek IDS: Balayage réseau détecté par $(srcip) sur le segment 192.168.100.0/24</description>
    <group>network_scan,reconnaissance</group>
    <mitre>
        <id>T1046</id>
    </mitre>
  </rule>
  
  
   <rule id="100004" level="11">
    <match>ALERTE_PORT_SCAN</match>
    <description>Zeek: Scan ports agressif détecté $(srcip) vers $(dstip)</description>
    <group>reconnaissance,attack,</group>
    <mitre>
        <id>T1046</id>
    </mitre>
  
  </rule>
  
  <rule id="100005" level="11">
    <match>ALERTE_ENUM_SERVICES</match>
    <description>Zeek: Enumeration de services détectée</description>
    <group>reconnaissance,attack,</group>
    <mitre>
        <id>T1046</id>
    </mitre>
</rule>
  
</group>



