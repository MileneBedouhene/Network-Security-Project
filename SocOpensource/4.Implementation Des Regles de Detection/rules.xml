<!-- Firewall Off -->
<group name="sysmon,persistence,windows,">

  <rule id="100601" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i).*netsh\.exe</field>
    
    <field name="win.eventdata.commandLine" type="pcre2">(?i).*advfirewall.*state\s+off</field>
    
    <description>ALERTE : Windows Firewall Deactivation via netsh by $(win.eventdata.user)</description>
    <mitre>
      <id>T1562.004</id>
    </mitre>
  </rule>

</group>






<!-- Log Deletion -->
<group name="sysmon,windows,defense_evasion,">

  <!-- Règle 1 : wevtutil / PowerShell via Sysmon EID 1 -->
  <rule id="100602" level="15">
    <if_sid>61603</if_sid>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(wevtutil\.exe|powershell\.exe)$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(wevtutil.*(cl|clear-log)|Clear-EventLog|EventLog.*Delete)</field>
    <description>Log deletion - Suppression de logs Windows détectée via $(win.eventdata.image) par $(win.eventdata.user)</description>
    <mitre>
      <id>T1070.001</id>
