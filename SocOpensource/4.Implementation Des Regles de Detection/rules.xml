<!-- xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx 1.2 Recon Interne xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx -->

<group name="sysmon,windows,post_compromise,">

  <!-- Détection : Recon Interne -->
  <rule id="100007" level="11">
    <if_sid>61603</if_sid>
    <field name="win.system.eventID">1</field>
    <match type="pcre2">(?i)(whoami\.exe|ipconfig\.exe|hostname\.exe|systeminfo\.exe)</match>
    <description>Reconnaissance locale détectée via commande système ($(win.eventdata.image), exécutée par $(win.eventdata.user))</description>
    <group>discovery,post_exploitation,</group>
    <mitre>
      <id>T1082</id>
    </mitre>
  </rule>
  
  <!-- Détection : ENUM AD -->
  <rule id="100008" level="11">
    <if_sid>61603</if_sid>
    <field name="win.system.eventID">^1$</field>
    <match type="pcre2">(?i)(net\s+user|net\s+group|net\s+localgroup|nltest|dsquery|adfind|Get-ADUser|Get-ADGroup|Get-ADComputer|Get-ADDomain)</match>
    <field name="win.eventdata.image" negate="yes">net1.exe</field>
    <description>ALERTE AD Reconnaissance détectée : $(win.eventdata.commandLine) par $(win.eventdata.user)</description>
    <group>active_directory,reconnaissance,discovery,sysmon</group>
    <mitre>
        <id>T1087</id>
    </mitre>
  </rule>

  <!-- Détection : ENUM Linux -->
  <rule id="100009" level="11">
    <if_group>audit</if_group>
    <field name="audit.file.name">/etc/passwd</field>
    <field name="audit.exe">cat|less|grep|awk|nano|vi</field>
    <description>Possible Linux enumeration activity on /etc/passwd</description>
    <mitre>
      <id>T1087</id>
    </mitre>
  </rule>

 
</group>



<!-- xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx 1.3 Bruteforce xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx -->


<!-- Détection Brute Force Login -->
<group name="authentication,windows,local">

    <!-- Détection : Echec Login-->
    <rule id="100010" level="11">
      <if_sid>60122</if_sid>
      <description>Failed login for $(win.eventdata.targetUserName)</description>
      <group>authentication_failed</group>
      <options>no_log</options>
    </rule>
   
   <!-- Détection : 3 tentatives de Login Echoues-->
   <rule id="100011" level="12" frequency="3" timeframe="120">
     <if_matched_sid>100010</if_matched_sid>
     <same_field>win.eventdata.ipAddress</same_field>
     <description>Brute Force detected from $(win.eventdata.ipAddress)</description>
     <group>bruteforce,authentication_attack</group>
     <mitre>
        <id>T1110</id>
     </mitre>
   </rule>
</group>



<!-- Détection Brute Force SSH -->
<group name="ssh,bruteforce,">

  <!-- Détection Brute Force password -->
  <rule id="100012" level="12" frequency="3" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>SSH Brute Force detected: more than 3 failed login attempts from $(srcip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>
  
  
  <!-- Détection Brute Force users -->
  <rule id="100013" level="11" frequency="3" timeframe="60">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>SSH username enumeration detected from $(srcip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

</group>






