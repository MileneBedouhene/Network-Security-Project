<!-- xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx 2. Delivery & Exploitation xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx -->


<!-- Certutil Abuse -->
<group name="windows,execution,custom">
  <rule id="100101" level="12">
    <if_sid>61603</if_sid>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)certutil\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(urlcache|http|https|ftp)</field>
    <description>Certutil abuse détecté : téléchargement potentiel via certutil ($(win.eventdata.commandLine))</description>
    <mitre>
      <id>T1105</id>
    </mitre>
  </rule>
</group>


<!-- mshta/regsvr32 -->
<group name="windows,execution,custom">
  <rule id="100102" level="12">
    <if_sid>61603</if_sid>
    <field name="win.system.eventID">^1$</field>
    <!-- Détection mshta ou regsvr32 -->
    <field name="win.eventdata.image" type="pcre2">(?i)(mshta\.exe|regsvr32\.exe)</field>
    <!-- Indicateurs de code distant -->
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(http|https|scrobj\.dll|javascript:|vbscript:)</field>
    <description>Exécution distante suspecte via mshta/regsvr32 ($(win.eventdata.commandLine))</description>
    <mitre>
      <id>T1218</id>
    </mitre>
  </rule>
</group>


<!-- Powershell obfusque -->

<group name="sysmon,powershell,windows,">

  <rule id="100103" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)-en[a-z]*\s+[A-Za-z0-9+/]{20,}={0,2}</field>
    <description>PowerShell obfusque - Commande encodee Base64 par user $(win.eventdata.user)</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1027</id>
    </mitre>
  </rule>

</group>



<!-- Download fichier -->
<group name="audit,download,linux,">

  <!-- Règle parente silencieuse : capte les events auditd execve génériques -->
  <rule id="100100" level="12">
    <if_sid>80700</if_sid>
    <field name="audit.key">wget_exec|curl_exec</field>
    <description>Auditd: execve détecté pour wget ou curl</description>
    <options>no_log</options>
  </rule>

  <!-- RÈGLE 100104 : Détection téléchargement fichier via wget/curl -->
  <rule id="100104" level="12">
    <if_sid>100100</if_sid>
    <field name="audit.exe">/usr/bin/wget|/usr/bin/curl</field>
    <description>Download fichier - Récupération de payload potentielle via $(audit.exe) par $(audit.auid)</description>
    <options>no_full_log</options>
    <group>download,payload_retrieval,pii,</group>
    <mitre>
      <id>T1105</id>  <!-- Ingress Tool Transfer -->
    </mitre>
  </rule>
</group>



<!-- Command Injection -->
<group name="audit,injection,linux,">

  <!-- Règle parente silencieuse : filtre sur la key auditd -->
  <rule id="100105" level="12">
    <if_sid>80700</if_sid>
    <field name="audit.key">cmd_injection</field>
    <description>Auditd: cmd_injection key détectée</description>
    <options>no_log</options>
  </rule>

  <!-- 100106 : Shell spawné sans TTY = injection suspecte -->
  <rule id="100106" level="12">
    <if_sid>100105</if_sid>
    <field name="audit.exe">/usr/bin/bash|/usr/bin/sh|/usr/bin/dash|/usr/bin/python3|/usr/bin/perl</field>
    <field name="audit.tty">\(none\)</field>
    <description>Command injection - Shell $(audit.exe) spawné sans TTY par user $(audit.auid)</description>
    <group>command_injection,shell_exec,high,</group>
    <mitre>
      <id>T1059</id>
      <id>T1059.004</id>
    </mitre>
   </rule>

  <!-- 100107 : Shell spawné depuis processus non interactif (apache, nginx, java...) -->
  <rule id="100107" level="14">
    <if_sid>100105</if_sid>
    <field name="audit.exe">/usr/bin/bash|/usr/bin/sh|/usr/bin/dash</field>
    <field name="audit.comm">apache2|nginx|httpd|java|node|php|python3|tomcat</field>
    <description>CRITIQUE - Shell spawné depuis service web $(audit.comm) par user $(audit.auid) - RCE probable</description>
    <group>command_injection,rce,critical,</group>
    <mitre>
      <id>T1059.004</id>
      <id>T1190</id>
    </mitre>
  </rule>

</group>




<!-- Execution au niveau du tmp -->
<group name="tmp,execution,linux,">
<rule id="100108" level="12">
  <if_sid>80700</if_sid>
  <field name="audit.key">tmp_exec</field>
  <description>Binaire $(audit.execve.a1) exécuté depuis /tmp par user $(audit.auid) : $(audit.execve.a0)</description>
  <mitre>
      <id>T1059</id>
      <id>T1204.002</id>
    </mitre>
</rule>

</group>


<!-- Alerte WAF-->

<group name="fortiweb,">
  <rule id="100109" level="12">
    <decoded_as>fortiweb-custom</decoded_as>
    <match>attack</match>
    <description>FortiWeb WAF: Tentative d'attaque bloquée détectée</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>attack_detected,pci_dss_11.4,</group>
    
  </rule>
</group>



