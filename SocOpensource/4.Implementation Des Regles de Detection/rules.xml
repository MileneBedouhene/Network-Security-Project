<!-- xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx 5.Exfiltration xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx -->

<!-- Compression native Windows -->
<group name="sysmon,windows,exfiltration,">

  <rule id="100400" level="12">
    <if_sid>61603</if_sid>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(makecab\.exe|compact\.exe)$</field>
    <field name="win.eventdata.user" negate="yes" type="pcre2">(?i)(NT AUTHORITY|SYSTEM|LOCAL SERVICE|NETWORK SERVICE)</field>
    <description>Compression - Outil natif Windows $(win.eventdata.image) par $(win.eventdata.user)</description>
    <mitre>
      <id>T1560.001</id>
    </mitre>
    <group>staging,pre_exfiltration,</group>
  </rule>

  <rule id="100401" level="12">
    <if_sid>61603</if_sid>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)Compress-Archive</field>
    <field name="win.eventdata.user" negate="yes" type="pcre2">(?i)(NT AUTHORITY|SYSTEM)</field>
    <description>Compression - Compress-Archive PowerShell par $(win.eventdata.user)</description>
    <mitre>
      <id>T1560.001</id>
    </mitre>
    <group>staging,pre_exfiltration,</group>
  </rule>

</group>




<!-- Large File Upload -->
<group name="sysmon,exfiltration,windows,">

  <rule id="100402" level="14">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image">curl\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-F|-T|--data).*http</field>
    <description>ALERTE : Data Exfiltration - curl used to upload data to an external URL by $(win.eventdata.user)</description>
    <mitre>
      <id>T1041</id>
    </mitre>
  </rule>

</group>




<!-- Transfert netcat -->
<group name="sysmon,exfiltration,windows,">

  <rule id="100403" level="14">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">nc\.exe|ncat\.exe|netcat\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i).*(-w\s+\d+|[\x3c\x3e].*|-e\s+| -lp )</field>
    <description>CRITICAL : Netcat Activity (Exfiltration/Shell) by $(win.eventdata.user)</description>
    <mitre>
      <id>T1041</id>
      <id>T1011</id>
    </mitre>
  </rule>
</group>


<!-- USB Copy -->
<group name="linux,usb,exfiltration,">

  <rule id="100404" level="12">
    <decoded_as>kernel</decoded_as>
    <match>key="usb_test_temp"</match>
    <description>ALERTE : USB copy - Détection de copie vers un périphérique USB (via Kernel Log).</description>
    <mitre>
      <id>T1052.001</id>
    </mitre>
  </rule>

</group>



