<!-- xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx 3. persistence xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx -->


<!-- Scheduled Task -->
<group name="sysmon,persistence,windows,">

  <rule id="100201" level="14">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)schtasks\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)schtasks.*/create</field>
    <description>ALERTE : Persistence - New Scheduled Task created by user $(win.eventdata.user)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
  </rule>

</group>


<!-- Registry Run -->

<group name="sysmon,persistence,windows,">

  <rule id="100202" level="12">
    <if_sid>92041</if_sid>
    <field name="win.eventdata.image">reg\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)add.*\\Run</field>
    <description>ALERTE : Persistence - Registry Run Key modified via reg.exe by $(win.eventdata.user)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
  </rule>

</group>

<!-- Cron modifié -->
<group name="linux,persistence,cron,">

  <rule id="100203" level="12">
    <if_sid>550</if_sid>
    <field name="file" type="pcre2">^/var/spool/cron/crontabs/|/etc/crontab|/etc/cron\.(d|daily|weekly|monthly)/</field>
    <description>ALERTE : Cron modifié - Détection d’une modification de crontab indiquant une persistance sur Linux.</description>
    <mitre>
      <id>T1053.003</id>
    </mitre>
  </rule>

</group>


<!-- Modif Sudoer-->
<group name="linux,privilege_escalation,">

  <rule id="100205" level="13">
    <if_sid>550</if_sid>
    <field name="file" type="pcre2">^/etc/sudoers$|^/etc/sudoers\.d/</field>
    <description>ALERTE : Modification sudoers - Détection de modification permettant une élévation de privilèges.</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

</group>


<!-- SSH Key-->
<group name="linux,persistence,ssh,">

  <rule id="100206" level="12">
    <if_sid>550</if_sid>
    <field name="file" type="pcre2">.*\.ssh/authorized_keys$</field>
    <description>ALERTE : SSH key - Détection d’ajout de clé SSH permettant un accès persistant sans authentification.</description>
    <mitre>
      <id>T1098.004</id>
    </mitre>
  </rule>

</group>




<!-- Détection de creation utilisateur linux -->
<group name="linux,persistence,">

  <rule id="100204" level="12">
    <if_group>audit</if_group>
    <field name="audit.type">SYSCALL</field>
    <!--<field name="audit.command">useradd</field>-->
    <field name="audit.execve.a0">^useradd$</field>
    <field name="audit.success">yes</field>
    <description>Persistence: new Linux user "$(audit.execve.a1)" created by "$(audit.auid)" </description>
    <mitre>
      <id>T1136</id>
    </mitre>
</rule>
</group>


